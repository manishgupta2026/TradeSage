# Copy this to .env and fill in your actual values
ANGEL_MARKET_KEY=your_market_key_here
ANGEL_HISTORICAL_KEY=your_historical_key_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_MPIN=your_mpin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# Trading Configuration
MAX_POSITIONS=5
ENABLE_CASH_BASED_LIMIT=true
MIN_SENTIMENT_FOR_OVERRIDE=0.4
MIN_CASH_PCT_FOR_OVERRIDE=0.15
SENTIMENT_THRESHOLD=-0.3
DAILY_LOSS_LIMIT=2500
MIN_RR_RATIO=2.0
