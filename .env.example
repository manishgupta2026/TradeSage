# ═══════════════════════════════════════════════════════════
#  TradeSage Environment Configuration
#  Copy to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════

# Angel One Broker Credentials
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# Legacy Angel One keys (used by existing scripts)
ANGEL_MARKET_KEY=your_market_key_here
ANGEL_HISTORICAL_KEY=your_historical_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_MPIN=your_mpin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Redis (Docker uses internal hostname)
REDIS_URL=redis://redis:6379
